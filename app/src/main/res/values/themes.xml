<resources>
    <style name="Theme.NightWave" parent="android:Theme.Material.NoActionBar">
        <!-- statusBarColor/navigationBarColor left unset (transparent) on purpose:
             enableEdgeToEdge() in MainActivity draws our own black Compose
             background behind the system bars, so they blend in seamlessly
             instead of showing as separate opaque black boxes. -->
        <item name="android:windowBackground">#000000</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
